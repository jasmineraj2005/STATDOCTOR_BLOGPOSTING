# StatDoctor Blog Pipeline — Environment Variables

# OpenAI API (required)
# Models used: gpt-4o (writer/intelligence), gpt-4o-mini (SEO/AHPRA)
OPENAI_API_KEY=sk-proj-...

# Guardian Open Platform API (required — news feed)
# Free key at: https://open-platform.theguardian.com/access/
# Free tier: 5,000 requests/day
GUARDIAN_API_KEY=your-guardian-api-key

# Unsplash API (optional — hero images)
# Free key at: https://unsplash.com/developers → New Application
# Free tier: 50 requests/hour
# Get the "Access Key" (not Secret Key)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
